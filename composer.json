{
    "require": {
        "laravel/sanctum": "^4.3",
        "spatie/laravel-medialibrary": "^11.21",
        "laravel/framework": "^13.0",
        "laravel/boost": "^2.4"
    },
    "require-dev": {
        "laravel/pail": "^1.2",
        "laravel/tinker": "^3.0",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.24"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/pail",
                "laravel/tinker"
            ]
        }
    }
}
